# Copy this file to .env and fill in your values
# backend/.env is gitignored — never commit real secrets

# Required — must be a strong random string (e.g. openssl rand -hex 32)
AUTH_SECRET=change-me-to-a-strong-random-secret

# Admin account seeded on first startup (required if starting with empty DB)
ADMIN_EMAIL=admin@fyintech.com
ADMIN_PASSWORD=change-me-strong-password

# External API keys
FIRECRAWL_API_KEY=
DEEPSEEK_API_KEY=
LIVEAVATAR_API_KEY=

# LiveAvatar IDs
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_VOICE_ID=

# Email
RESEND_API_KEY=
# Sender address shown in notification emails (must be a verified Resend domain)
RESEND_SENDER=FY Intech CRM <noreply@yourdomain.com>

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Optional — session token lifetime in seconds (default: 8 hours)
# AUTH_TOKEN_TTL_SECONDS=28800
